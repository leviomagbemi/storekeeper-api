  "definitions": {
    "SupplierInput": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "example": "Tech Source Ltd"
        },
        "email": {
          "type": "string",
          "example": "sales@techsource.com"
        },
        "phone": {
          "type": "string",
          "example": "+2348012345678"
        },
        "address": {
          "type": "string",
          "example": "12 Warehouse Road, Lagos"
        },
        "contactPerson": {
          "type": "string",
          "example": "Ada Johnson"
        }
      }
    },
    "ItemInput": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "example": "Wireless Mouse"
        },
        "sku": {
          "type": "string",
          "example": "WM-1001"
        },
        "category": {
          "type": "string",
          "example": "Electronics"
        },
        "quantityInStock": {
          "type": "number",
          "example": 25
        },
        "unitPrice": {
          "type": "number",
          "example": 19.99
        },
        "supplier": {
          "type": "string",
          "example": "65f0749dbe57a3fb53c0b111"
        },
        "reorderLevel": {
          "type": "number",
          "example": 10
        },
        "location": {
          "type": "string",
          "example": "Shelf A3"
        },
        "description": {
          "type": "string",
          "example": "Compact wireless mouse"
        },
        "lastRestocked": {
          "type": "string",
          "example": "2026-03-20T00:00:00.000Z"
        }
      }
    }
  }
